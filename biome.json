{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist",
      "!.wrangler",
      "!packages/server/src/worker-configuration.d.ts",
      "!migrations/meta",
      "!assets/index.json",
      "!assets/lindocara-asset-catalog.json",
      "!public/assets/lindocara/tiny-swords/catalog.json",
      "!packages/engine/src/tiny-swords-catalog.generated.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/server/src/**",
        "packages/client/src/game/session.ts",
        "packages/renderer/src/input.ts"
      ],
      "linter": {
        "enabled": true,
        "rules": {
          "correctness": {
            "useHookAtTopLevel": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/engine/src/event-commands.ts",
        "packages/engine/src/event-interpreter.ts",
        "packages/server/src/world/event-run-system.ts",
        "packages/client/src/ui/editor/EventCommandEditor.tsx",
        "test/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noThenProperty": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "actions": {
      "source": { "organizeImports": "on" }
    }
  }
}
