{
  // Build tooling and the pure-logic (engine) tests: all run in Node, not a browser or workerd.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "packages/*/vitest.config.ts",
    "packages/server/drizzle.config.ts",
    "scripts/**/*.ts",
    "packages/engine/test/**/*.ts"
  ]
}
