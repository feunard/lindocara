{
  // The React front end: app shell, screens, HUD, shadcn/Tiny-Swords component trees, the client
  // store, api and the game-session glue (net/input/sound/session). Browser + React. Depends on
  // engine and renderer. The `@/` alias is the client source root and is shared (via the Vite
  // alias) with the editor package, which builds on this base.
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"]
}
