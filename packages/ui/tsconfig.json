{
  // The stock shadcn component tree (base-nova / neutral). Browser + React, no engine/renderer
  // dependency — just the shadcn primitives, cn and the shared tokens. Regenerated by `shadcn add`.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
