# Copy to `.dev.vars` for local development (`.dev.vars` is gitignored).
#
# Generate a real value with:
#   openssl rand -base64 32
#
# In production this is set once with:
#   npx wrangler secret put SESSION_SECRET
SESSION_SECRET="dev-secret-not-for-production"
NAVIGATION_DEBUG="false"
# Local test commands such as /up10 and /nodead. Never set this in production.
CHEATS_ENABLED="true"
