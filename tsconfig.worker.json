{
  // The Worker, the Durable Object, and the tests that exercise them — all run in workerd.
  // No DOM lib here; the runtime globals come from the generated worker-configuration.d.ts.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/vitest-pool-workers/types"]
  },
  "include": [
    "src/server/**/*.ts",
    "src/shared/**/*.ts",
    "test/**/*.ts",
    "src/worker-configuration.d.ts",
    "src/env.d.ts"
  ]
}
