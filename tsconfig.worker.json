{
  // The workerd-side test program: the DO/integration tests under test/ (excluding the jsdom
  // React suite and the plain client suite). Package *sources* are typechecked by their own
  // per-package tsconfig; this program covers the tests that exercise them. The runtime globals
  // come from the generated worker-configuration.d.ts and the vitest-pool-workers types.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/vitest-pool-workers/types"]
  },
  "include": [
    "test/**/*.ts",
    "packages/server/src/worker-configuration.d.ts",
    "packages/server/src/env.d.ts"
  ],
  // test/ui/ is the jsdom React suite and test/client/ is the plain (non-React) client suite,
  // both checked by tsconfig.client.json.
  "exclude": ["test/ui", "test/client"]
}
