{
  "name": "lindocara",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest run -c vitest.ui.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "loadtest": "node scripts/loadtest.mjs",
    "map:build": "tsx scripts/build-map.ts",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.node.json",
    "cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply lindocara --local",
    "db:migrate:remote": "wrangler d1 migrations apply lindocara --remote",
    "check": "npm run lint && npm run typecheck && npm run test && npm run test:ui"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/vite-plugin": "^1.43.3",
    "@cloudflare/vitest-pool-workers": "^0.18.3",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.109.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pixi.js": "^8.19.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
