{
  "name": "lindocara",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:engine": "vitest run --project engine",
    "test:server": "vitest run --project server",
    "test:renderer": "vitest run --project renderer",
    "test:client": "vitest run --project client",
    "test:editor": "vitest run --project editor",
    "test:ui": "vitest run --project renderer --project client --project editor",
    "test:runtime": "vitest run --project engine --project server --project renderer --project client",
    "test:ui:runtime": "vitest run --project renderer --project client",
    "test:catalog": "vitest run --project engine catalog.test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "loadtest": "node scripts/loadtest.mjs",
    "map:build": "tsx scripts/build-map.ts",
    "map:check": "npm run map:build && git diff --exit-code -- packages/engine/src/zones/verdant-reach-tiles.ts packages/engine/src/zones/mmo-test-zone-tiles.ts packages/engine/src/zones/sunken-isles-tiles.ts",
    "catalog:build": "tsx scripts/build-tiny-swords-catalog.ts",
    "catalog:check": "tsx scripts/check-tiny-swords-catalog.ts && npm run test:catalog",
    "format": "biome format --write .",
    "typecheck": "npm run typecheck:engine && npm run typecheck:server && npm run typecheck:renderer && npm run typecheck:client && npm run typecheck:editor && npm run typecheck:ui && npm run typecheck:testing && tsc -p tsconfig.client.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.node.json",
    "typecheck:engine": "tsc -p packages/engine/tsconfig.json",
    "typecheck:server": "tsc -p packages/server/tsconfig.json",
    "typecheck:renderer": "tsc -p packages/renderer/tsconfig.json",
    "typecheck:client": "tsc -p packages/client/tsconfig.json",
    "typecheck:editor": "tsc -p packages/editor/tsconfig.json",
    "typecheck:ui": "tsc -p packages/ui/tsconfig.json",
    "typecheck:testing": "tsc -p packages/testing/tsconfig.json",
    "cf-typegen": "wrangler types ./packages/server/src/worker-configuration.d.ts",
    "ui:add": "shadcn add -c packages/ui",
    "db:generate": "drizzle-kit generate --config packages/server/drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply lindocara --local",
    "db:migrate:remote": "wrangler d1 migrations apply lindocara --remote",
    "check": "npm run catalog:check && npm run map:check && npm run lint && npm run typecheck && npm run test",
    "check:runtime": "npm run lint && npm run typecheck && npm run test:runtime && npm run test:ui:runtime && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.3.2",
    "tsx": "4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0",
    "ws": "^8.21.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.4"
    }
  }
}
